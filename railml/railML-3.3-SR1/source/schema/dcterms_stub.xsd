<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal stub for the Dublin Core Terms namespace (http://purl.org/dc/terms/).
  The real schema lives at http://dublincore.org/schemas/xmls/qdc/2008/02/11/dcterms.xsd
  but that host blocks automated fetches.  Only the types actually referenced by
  railML 3.3 (common3.xsd uses elementOrRefinementContainer as a base type for
  the <metadata> element) need to be declared here.
-->
<xs:schema
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    xmlns:dcterms="http://purl.org/dc/terms/"
    targetNamespace="http://purl.org/dc/terms/"
    elementFormDefault="qualified">

  <xs:complexType name="elementOrRefinementContainer">
    <xs:sequence>
      <xs:any namespace="##any" minOccurs="0" maxOccurs="unbounded" processContents="lax"/>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
